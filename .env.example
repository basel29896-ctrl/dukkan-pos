# Copy this to .env and fill in your values. NEVER commit real secrets.

# ── React app vars (must have REACT_APP_ prefix to reach the browser) ─────────
# Empty = same origin as the API (the normal single-dyno deploy).
REACT_APP_API_URL=

# Sentry error tracking (optional — leave blank to disable)
REACT_APP_SENTRY_DSN=

# ── Heroku API server (server/) ───────────────────────────────────────────────
# Set on Heroku via `heroku config:set`. DATABASE_URL is provided by the Postgres addon.
DATABASE_URL=postgres://user:pass@host:5432/dbname
NODE_ENV=development
PORT=3001
SESSION_TTL_HOURS=12

# First-admin bootstrap (used once by `npm run seed:admin`, then unset)
ADMIN_USERNAME=owner
ADMIN_PASSWORD=P@ssw0rd
ADMIN_EMAIL=

# ── Forgot-password email (optional) ──────────────────────────────────────────
# Server-side EmailJS REST. Without these, login works but admin forgot-password
# returns 503. Enable "Allow EmailJS API for non-browser applications" in EmailJS.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
